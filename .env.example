# TriLink Environment Variables
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to git!

# ─── Supabase ───────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_ANON_KEY

# ─── Strava OAuth ───────────────────────────────────────────────────────────
# Get from: https://www.strava.com/settings/api
# In Strava app settings, set "Authorization Callback Domain" to your domain
# Authorized Redirect URI (add both):
#   Dev:  http://localhost:8080/auth/strava/callback
#   Prod: https://yourdomain.com/auth/strava/callback
VITE_STRAVA_CLIENT_ID=YOUR_STRAVA_CLIENT_ID

# ─── Supabase Edge Function Secrets ─────────────────────────────────────────
# Set these via Supabase Dashboard → Edge Functions → Secrets
# or via CLI: supabase secrets set KEY=value
#
# STRAVA_CLIENT_ID=same as VITE_STRAVA_CLIENT_ID above
# STRAVA_CLIENT_SECRET=your_strava_client_secret
